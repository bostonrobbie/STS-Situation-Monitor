STS_ENV=dev
STS_API_PORT=8080
STS_DATABASE_URL=sqlite:///./sts_monitor.db
# STS_DATABASE_URL=postgresql://sts:sts@localhost:5432/sts
STS_REDIS_URL=redis://localhost:6379/0
STS_QDRANT_URL=http://localhost:6333
STS_LOCAL_LLM_URL=http://localhost:11434
STS_LOCAL_LLM_MODEL=llama3.1
STS_LOCAL_LLM_TIMEOUT_S=10
STS_WORKSPACE_ROOT=.
STS_LOCAL_LLM_MAX_RETRIES=2
STS_AUTH_API_KEY=change-me
STS_ENFORCE_AUTH=true
STS_RSS_TIMEOUT_S=10
STS_RSS_MAX_RETRIES=2
STS_REDDIT_TIMEOUT_S=10
STS_REDDIT_USER_AGENT=STS-Situation-Monitor/0.6
STS_JOB_MAX_ATTEMPTS=3
STS_JOB_RETRY_BACKOFF_S=10
STS_PUBLIC_BASE_URL=http://localhost:8080
STS_CORS_ORIGINS=
STS_TRUSTED_HOSTS=*
STS_ALERT_WEBHOOK_URL=
STS_ALERT_WEBHOOK_TIMEOUT_S=5
STS_ENFORCE_REPORT_LINEAGE_GATE=false
STS_REPORT_MIN_LINEAGE_COVERAGE=0.7

# --- Data Source Connectors ---
# GDELT (free, no auth)
STS_GDELT_TIMEOUT_S=15
STS_GDELT_DEFAULT_TIMESPAN=3h
STS_GDELT_MAX_RECORDS=75

# USGS Earthquake (free, no auth)
STS_USGS_MIN_MAGNITUDE=4.0
STS_USGS_TIMEOUT_S=10
STS_USGS_LOOKBACK_HOURS=24

# NASA FIRMS Fire Hotspots (free, requires MAP_KEY from https://firms.modaps.eosdis.nasa.gov/api/area/)
STS_NASA_FIRMS_MAP_KEY=
STS_NASA_FIRMS_TIMEOUT_S=15
STS_NASA_FIRMS_SENSOR=VIIRS_NOAA20_NRT

# ACLED Conflict Data (free registration at https://developer.acleddata.com/)
STS_ACLED_API_KEY=
STS_ACLED_EMAIL=
STS_ACLED_TIMEOUT_S=15
STS_ACLED_LOOKBACK_DAYS=7

# NWS Weather Alerts (free, no auth, US only)
STS_NWS_SEVERITY_FILTER=Extreme,Severe
STS_NWS_TIMEOUT_S=10

# FEMA Disaster Declarations (free, no auth)
STS_FEMA_TIMEOUT_S=10
STS_FEMA_LOOKBACK_DAYS=30

# ReliefWeb Humanitarian Reports (free, no auth)
STS_RELIEFWEB_TIMEOUT_S=15

# OpenSky Aircraft Tracking (free, no auth for public API)
STS_OPENSKY_TIMEOUT_S=15

# Webcam / Camera Monitoring
# Windy Webcams API (free tier: 25 req/day, get key at https://api.windy.com/webcams)
STS_WINDY_API_KEY=
STS_WEBCAM_TIMEOUT_S=10
STS_WEBCAM_DEFAULT_REGIONS=

# --- Nitter / Twitter ---
# Comma-separated Nitter instances (leave empty for defaults)
STS_NITTER_INSTANCES=
STS_NITTER_TIMEOUT_S=12
# Comma-separated OSINT account categories: conflict,natural_disaster,geopolitics,osint
STS_NITTER_CATEGORIES=

# --- Web Scraper ---
STS_SCRAPER_TIMEOUT_S=15
STS_SCRAPER_MAX_DEPTH=2
STS_SCRAPER_MAX_PAGES=50
STS_SCRAPER_DELAY_S=1.0

# --- Search Engine (DuckDuckGo, no auth) ---
STS_SEARCH_MAX_RESULTS=20
STS_SEARCH_TIMEOUT_S=15

# --- Autonomous Research Agent ---
STS_AGENT_MAX_ITERATIONS=5
STS_AGENT_MAX_OBSERVATIONS=500
STS_AGENT_INTER_ITERATION_DELAY_S=5
STS_AGENT_LLM_TIMEOUT_S=60

# --- Embeddings / Semantic Search (requires Qdrant + Ollama embedding model) ---
# Run: ollama pull nomic-embed-text
STS_EMBEDDING_MODEL=nomic-embed-text
STS_EMBEDDING_TIMEOUT_S=30
STS_QDRANT_TIMEOUT_S=15
STS_QDRANT_VECTOR_SIZE=768

# --- ADS-B Exchange (requires API key from https://www.adsbexchange.com/data/) ---
STS_ADSB_API_KEY=
STS_ADSB_TIMEOUT_S=15

# --- Marine Traffic (requires API key from https://www.marinetraffic.com/en/ais-api-services) ---
STS_MARINE_API_KEY=
STS_MARINE_TIMEOUT_S=15

# --- Telegram (public channels, no auth for scraping) ---
STS_TELEGRAM_TIMEOUT_S=15

# --- Internet Archive / Wayback Machine (free, no auth) ---
STS_ARCHIVE_TIMEOUT_S=15

# --- Privacy Layer ---
# Enable PII redaction before storage (strips names, emails, phones)
STS_PRIVACY_REDACT_PII=false

# --- Data Retention ---
STS_RETENTION_MAX_AGE_DAYS=90

# --- Cycle Orchestrator ---
# Minimum reliability score for pipeline filtering (0.0-1.0)
STS_CYCLE_MIN_RELIABILITY=0.45
# Enable report generation in cycle runs
STS_CYCLE_GENERATE_REPORT=true

# --- JWT Authentication ---
STS_JWT_SECRET=change-me-in-production
STS_JWT_EXPIRY_HOURS=24

# --- Rate Limiting ---
STS_RATE_LIMIT_RPM=120
STS_RATE_LIMIT_BURST=30
STS_RATE_LIMIT_ENABLED=true

# --- Email Notifications (SMTP) ---
STS_SMTP_HOST=
STS_SMTP_PORT=587
STS_SMTP_USER=
STS_SMTP_PASSWORD=
STS_SMTP_FROM=sts-monitor@localhost
STS_SMTP_TO=

# --- Slack Notifications ---
STS_SLACK_WEBHOOK_URL=
STS_SLACK_CHANNEL=

# --- Plugin System ---
# Directory for custom connector plugins (default: ~/.sts-monitor/plugins)
STS_PLUGIN_DIR=

# --- Autopilot (automatic intelligence cycling) ---
# Enable autopilot on startup (auto-processes active investigations)
STS_AUTOPILOT_ENABLED=false
# Interval between cycles in seconds (default 300 = 5 min)
STS_AUTOPILOT_INTERVAL_S=300
# Observations to ingest per cycle per investigation
STS_AUTOPILOT_BATCH_SIZE=15
# Use local LLM for entity extraction (requires Ollama running)
STS_AUTOPILOT_USE_LLM=true
# Run autonomous research agent in cycles (more resource-intensive)
STS_AUTOPILOT_RUN_AGENT=false
# Max investigations to process per cycle
STS_AUTOPILOT_MAX_INVESTIGATIONS=10
# Use real OSINT connectors (GDELT, NWS, USGS, Reddit) instead of simulated data
STS_AUTOPILOT_USE_REAL_CONNECTORS=true
